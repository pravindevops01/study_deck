<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Productivity Deck Companion</title>
    <style>
        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
            background-color: #f4f4f9;
            color: #333;
            margin: 0;
            padding: 20px;
            display: flex;
            flex-direction: column;
            align-items: center;
        }
        .container {
            width: 100%;
            max-width: 400px;
            background: white;
            padding: 20px;
            border-radius: 12px;
            box-shadow: 0 4px 10px rgba(0,0,0,0.1);
            margin-bottom: 20px;
        }
        h2 { margin-top: 0; color: #4A90E2; }
        button {
            width: 100%;
            padding: 12px;
            background-color: #4A90E2;
            color: white;
            border: none;
            border-radius: 8px;
            font-size: 16px;
            font-weight: bold;
            cursor: pointer;
            margin-top: 10px;
        }
        button:active { background-color: #357ABD; }
        input[type="text"] {
            width: calc(100% - 24px);
            padding: 10px;
            border: 1px solid #ccc;
            border-radius: 8px;
            font-size: 16px;
            margin-top: 10px;
        }
        .flashcard {
            background: #fffdf0;
            border: 2px dashed #f39c12;
            padding: 30px 10px;
            text-align: center;
            font-size: 20px;
            font-weight: bold;
            border-radius: 8px;
            margin-top: 15px;
            min-height: 60px;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .status { font-size: 14px; color: #777; text-align: center; margin-top: 5px; }
    </style>
</head>
<body>

    <div class="container">
        <h2>🔌 Hardware Link</h2>
        <button id="connectBtn" onclick="connectBluetooth()">Connect to ESP32</button>
        <div class="status" id="statusLabel">Status: Disconnected</div>
    </div>

    <div class="container">
        <h2>📝 Push Tasks</h2>
        <input type="text" id="taskInput" placeholder="Type homework / chores here...">
        <button onclick="sendTask()">Send to Console</button>
    </div>

    <div class="container">
        <h2>🗂️ Study Flashcards</h2>
        <div class="flashcard" id="cardDisplay">Tap Next to Start!</div>
        <button style="background-color: #f39c12;" onclick="toggleFlashcard()">👁️ Reveal Answer / Question</button>
        <button style="background-color: #2ecc71;" onclick="nextFlashcard()">➡️ Next Card</button>
    </div>

    <script>
        let bluetoothDevice = null;
        let txCharacteristic = null;

        // Flashcard Database Arrays
        const questions = ["What is 5 x 5?", "ESP32 Tx Pin default?", "Powerhouse of the cell?", "Formula for Force?"];
        const answers = ["25", "GPIO 1 (Transmit)", "Mitochondria", "Mass x Acceleration (F=ma)"];
        let cardIndex = 0;
        let showingQuestion = true;

        // Bluetooth Protocol Handler
        async function connectBluetooth() {
            try {
                document.getElementById("statusLabel").innerText = "Searching for ESP32...";
                // Web Bluetooth api scans for your target profile
                bluetoothDevice = await navigator.bluetooth.requestDevice({
                    acceptAllDevices: true,
                    optionalServices: ['00001101-0000-1000-8000-00805f9b34fb'] // Classic Serial Profile UUID
                });
                
                const server = await bluetoothDevice.gatt.connect();
                document.getElementById("statusLabel").innerText = "Connected! ✅";
                document.getElementById("connectBtn").innerText = "Linked";
            } catch (error) {
                document.getElementById("statusLabel").innerText = "Connection Failed.";
                console.log(error);
            }
        }

        async function sendTask() {
            let taskText = document.getElementById("taskInput").value;
            if (!taskText) return;
            
            // Append newline character \n so ESP32 splits strings accurately
            let formattedPackage = taskText + "\n"; 
            
            if (txCharacteristic) {
                let encoder = new TextEncoder();
                await txCharacteristic.writeValue(encoder.encode(formattedPackage));
                document.getElementById("taskInput").value = "";
            } else {
                alert("Please connect the hardware Bluetooth unit first!");
            }
        }

        // Flashcard Cycle Mechanics
        function nextFlashcard() {
            cardIndex = (cardIndex + 1) % questions.length;
            showingQuestion = true;
            document.getElementById("cardDisplay").innerText = questions[cardIndex];
        }

        function toggleFlashcard() {
            showingQuestion = !showingQuestion;
            document.getElementById("cardDisplay").innerText = showingQuestion ? questions[cardIndex] : answers[cardIndex];
        }
    </script>
</body>
</html>
